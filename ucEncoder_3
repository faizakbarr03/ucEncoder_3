float r1_ema = 0.0, r2_ema = 0.0;

int nilaiEMAKiri(int r1Baru){
  r1_ema = EMA_ALPHA * r1Baru + (1.0 - EMA_ALPHA) * r1_ema;
  return round (r1_ema);
}

int nilaiEMAKanan (int r2Baru) {
  r2_ema = EMA_ALPHA * r2Baru + (1.0 - EMA_ALPHA) * r2_ema;
  return round(r2_ema);
}

void setup() {
  Serial.begin(57600);
//  pinMode(analog_pin, OUTPUT);// Jangan sampai muncul ini. Jika dilakukan akan menghasilkan PWM
  pinMode(PIN_RPM_KIRI, INPUT_PULLUP); 
  attachInterrupt(digitalPinToInterrupt(PIN_RPM_KIRI), isr_pulsaKiri, RISING);
  pinMode(PIN_RPM_KANAN, INPUT_PULLUP); 
  attachInterrupt(digitalPinToInterrupt(PIN_RPM_KANAN), isr_pulsaKanan, RISING);
  // nh.initNode();
