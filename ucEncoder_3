/**
** Program ini jalan di microcontroller Adafruit Feather M4 CAN.
** Program mengirimkan rpm melalui pin analog A0
** RPM didapatkan dengan menghitung jumlah pulsa selama satu interval (110 ms)
** PulsaKiri akan bertambah jika gigi melewati led dari encoder.
** Encoder dilengkapi roda gigi yang mempunyai 16 gigi.
** Selanjutnya diukur rata-rata rpm dan dikirim lewat DAC 12bit
**/
#include <Wire.h> 
// #include <ros.h>
// #include <std_msgs/Float32.h>

float EMA_ALPHA = 0.05;

#define PIN_RPM_KIRI      10         // Pin 12 dari Adafruit
#define PIN_RPM_KANAN     11         // Pin D2 mapped to pin GPI13 of ESP8266

volatile int pulsaKiri=0;
volatile int pulsaKanan=0;
volatile unsigned long intervalTimeKiri = 0;
volatile unsigned long previousInterruptTimeKiri = 0;
volatile unsigned long intervalTimeKanan = 0;
volatile unsigned long previousInterruptTimeKanan = 0;

// Minumum and maximum values for 16-bit integers
const int encoder_minimum = -512;
const int encoder_maximum = 511;
const int analog_pin1 = A0;
const int analog_pin2 = A1;

/**
** Dihitung pulsa disebabkan gigi kiri melintas
** selama lebih besar dari 5 microsecond dari perhitungan sebelumnya
** untuk menghindari perhitungan derau setelah pulsa naik.
**/
void isr_pulsaKiri() {
  previousInterruptTimeKiri = intervalTimeKiri;
  intervalTimeKiri = micros();
  if (intervalTimeKiri - previousInterruptTimeKiri > 5) { //0.05ms
    if (pulsaKiri == encoder_maximum) {
      pulsaKiri = encoder_minimum;
    }
    else {
      pulsaKiri++;  
    }      
  }
}
 
/**
** Dihitung pulsa yang disebabkan gigi kanan melintas
** selama lebih besar dari 5 microsecond dari perhitungan sebelumnya
** untuk menghindari perhitungan derau setelah pulsa naik.
**/
void isr_pulsaKanan() {
  previousInterruptTimeKanan = intervalTimeKanan;
  intervalTimeKanan = micros();
  if (intervalTimeKanan - previousInterruptTimeKanan > 5) { //0.05ms
    if (pulsaKanan == encoder_maximum) {
      pulsaKanan = encoder_minimum;
    }
    
    else {
      pulsaKanan++;  
    }      
  }
}

